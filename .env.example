# Database (MySQL)
# Perfil prod: MYSQL_CONNECTION / MYSQL_USER / MYSQL_PASSWORD
# Sin perfil prod: DB_URL / DB_USERNAME / DB_PASSWORD

SPRING_PROFILES_ACTIVE=prod
MYSQL_CONNECTION=jdbc:mysql://localhost:3306/meditrack_devices?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
MYSQL_USER=meditrack
MYSQL_PASSWORD=

# Alternativa sin perfil prod:
# DB_URL=jdbc:mysql://localhost:3306/meditrack_devices?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_USERNAME=meditrack
# DB_PASSWORD=

# Clinical — direct REST (no gateway)
CLINICAL_SERVICE_URL=https://meditrack-clinical-hph0avgbe2ejbyew.eastus-01.azurewebsites.net
CLINICAL_THRESHOLD_CACHE_TTL_SECONDS=120
CLINICAL_CONNECT_TIMEOUT_SECONDS=3
CLINICAL_READ_TIMEOUT_SECONDS=5

# MQTT — Mosquitto en la misma VM (FOG)
MQTT_ENABLED=true
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_TELEMETRY_TOPIC=meditrack/devices/telemetry
MQTT_CLIENT_ID=meditrack-devices
